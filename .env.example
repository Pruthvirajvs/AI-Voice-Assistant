# Copy this file to .env or set these variables in Windows Environment Variables.
# Do not commit real keys.

ASSISTANT_NAME=Jarvis
DEFAULT_CITY=Bengaluru
OPENWEATHER_API_KEY=replace-with-openweather-key
WOLFRAMALPHA_APP_ID=replace-with-wolframalpha-app-id
MUSIC_DIR=C:\Users\YourName\Music
SCREENSHOT_DIR=C:\Users\YourName\Pictures\Assistant Screenshots
DOWNLOAD_DIR=C:\Users\YourName\Downloads
NOTES_FILE=note.txt
MEMORY_FILE=data.txt
